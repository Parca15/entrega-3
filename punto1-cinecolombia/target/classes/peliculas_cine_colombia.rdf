    <!-- ══════════════════════════════════════════════════════
         SECCIÓN 1 — DEFINICIÓN DE CLASES
         ══════════════════════════════════════════════════════ -->

    <rdfs:Class rdf:about="http://cinecolombia.com/ontologia#Pelicula">
