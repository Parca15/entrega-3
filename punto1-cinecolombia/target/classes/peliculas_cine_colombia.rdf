    <!-- ══════════════════════════════════════════════════════
         SECCIÓN 5 — PELÍCULAS EN CARTELERA (14 may 2026)
         Fuente: Colombia.com / Cine Colombia
         ══════════════════════════════════════════════════════ -->

    <!-- ─── PELÍCULA 1: En La Zona Gris ─────────────────── -->
    <cine:Pelicula rdf:about="http://cinecolombia.com/pelicula/EnLaZonaGris2026">
        <rdf:type rdf:resource="https://schema.org/Movie"/>
        <dc:title>En La Zona Gris</dc:title>
        <dc:description xml:lang="es">
            Dos especialistas en extracción deben designar una ruta de escape
            para una negociadora de alto rango en medio de una misión peligrosa.
        </dc:description>
        <cine:duracionMinutos rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">98</cine:duracionMinutos>
        <cine:fechaEstreno rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-14</cine:fechaEstreno>
        <cine:genero rdf:resource="http://cinecolombia.com/genero/Thriller"/>
        <cine:clasificacion rdf:resource="http://cinecolombia.com/clasificacion/Mayores12"/>
        <cine:disponible3D rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</cine:disponible3D>
        <cine:distribuidora>Diamond Films</cine:distribuidora>
        <cine:enCartelera rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</cine:enCartelera>
        <rdfs:seeAlso rdf:resource="https://www.colombia.com/cine/en-la-zona-gris-12088"/>
    </cine:Pelicula>

    <!-- ─── PELÍCULA 2: Mortal Kombat II ─────────────────── -->
    <cine:Pelicula rdf:about="http://cinecolombia.com/pelicula/MortalKombatII2026">
        <rdf:type rdf:resource="https://schema.org/Movie"/>
        <dc:title>Mortal Kombat II</dc:title>
        <dc:description xml:lang="es">
            Los campeones favoritos de los fans, acompañados por Johnny Cage,
            se enfrentan en la batalla definitiva contra el oscuro régimen de
            Shao Kahn, que amenaza la existencia del Reino de la Tierra.
        </dc:description>
        <cine:duracionMinutos rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">116</cine:duracionMinutos>
        <cine:fechaEstreno rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-07</cine:fechaEstreno>
        <cine:genero rdf:resource="http://cinecolombia.com/genero/Accion"/>
        <cine:clasificacion rdf:resource="http://cinecolombia.com/clasificacion/Mayores15"/>
        <cine:director rdf:resource="http://cinecolombia.com/director/SimonMcQuoid"/>
        <cine:disponible3D rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</cine:disponible3D>
        <cine:distribuidora>Warner Bros.</cine:distribuidora>
        <cine:enCartelera rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</cine:enCartelera>
        <schema:actor>Lewis Tan</schema:actor>
        <schema:actor>Jessica McNamee</schema:actor>
        <schema:actor>Josh Lawson</schema:actor>
        <rdfs:seeAlso rdf:resource="https://www.colombia.com/cine/mortal-kombat-ii-12068"/>
    </cine:Pelicula>

    <!-- ─── PELÍCULA 3: Michael ───────────────────────────── -->
    <cine:Pelicula rdf:about="http://cinecolombia.com/pelicula/Michael2026">
        <rdf:type rdf:resource="https://schema.org/Movie"/>
        <dc:title>Michael</dc:title>
        <dc:description xml:lang="es">
            Retrato íntimo de la vida y el legado de Michael Jackson, protagonizado
            por Jaafar Jackson en su debut cinematográfico, desde sus inicios con
            los Jackson Five hasta convertirse en el artista más grande del mundo.
        </dc:description>
        <cine:duracionMinutos rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">127</cine:duracionMinutos>
        <cine:fechaEstreno rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-09</cine:fechaEstreno>
        <cine:genero rdf:resource="http://cinecolombia.com/genero/Biopic"/>
        <cine:clasificacion rdf:resource="http://cinecolombia.com/clasificacion/Mayores12"/>
        <cine:director rdf:resource="http://cinecolombia.com/director/AntoineFuqua"/>
        <cine:disponible3D rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</cine:disponible3D>
        <cine:distribuidora>Universal Pictures</cine:distribuidora>
        <cine:enCartelera rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</cine:enCartelera>
        <schema:actor>Jaafar Jackson</schema:actor>
        <rdfs:seeAlso rdf:resource="https://www.colombia.com/cine/michael-12048"/>
    </cine:Pelicula>

    <!-- ─── PELÍCULA 4: El Diablo Viste a la Moda 2 ─────── -->
    <cine:Pelicula rdf:about="http://cinecolombia.com/pelicula/ElDiabloVisteALaModa2">
        <rdf:type rdf:resource="https://schema.org/Movie"/>
        <dc:title>El Diablo Viste a la Moda 2</dc:title>
        <dc:description xml:lang="es">
            Casi veinte años después, Meryl Streep, Anne Hathaway, Emily Blunt y
            Stanley Tucci regresan a las elegantes calles de Nueva York y a las
            sofisticadas oficinas de la revista Runway en la esperada secuela.
        </dc:description>
        <cine:duracionMinutos rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">120</cine:duracionMinutos>
        <cine:fechaEstreno rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-07</cine:fechaEstreno>
        <cine:genero rdf:resource="http://cinecolombia.com/genero/Comedia"/>
        <cine:clasificacion rdf:resource="http://cinecolombia.com/clasificacion/Mayores7"/>
        <cine:director rdf:resource="http://cinecolombia.com/director/DavidFrankel"/>
        <cine:disponible3D rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</cine:disponible3D>
        <cine:distribuidora>20th Century Studios</cine:distribuidora>
        <cine:enCartelera rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</cine:enCartelera>
        <schema:actor>Meryl Streep</schema:actor>
        <schema:actor>Anne Hathaway</schema:actor>
        <schema:actor>Emily Blunt</schema:actor>
        <schema:actor>Stanley Tucci</schema:actor>
        <rdfs:seeAlso rdf:resource="https://www.colombia.com/cine/el-diablo-viste-a-la-moda-2-12054"/>
    </cine:Pelicula>

    <!-- ─── PELÍCULA 5: Super Mario Galaxy: La Película ──── -->
    <cine:Pelicula rdf:about="http://cinecolombia.com/pelicula/SuperMarioGalaxy2026">
        <rdf:type rdf:resource="https://schema.org/Movie"/>
        <dc:title>Super Mario Galaxy: La Película</dc:title>
        <dc:description xml:lang="es">
            Mario y Luigi salen del Reino Champiñón para una aventura intergaláctica.
            La batalla se traslada al espacio y Bowser Jr. se les cruza en el camino.
            Con aliados inesperados, el destino del universo queda en juego.
        </dc:description>
        <cine:duracionMinutos rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">115</cine:duracionMinutos>
        <cine:fechaEstreno rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-07</cine:fechaEstreno>
        <cine:genero rdf:resource="http://cinecolombia.com/genero/Animacion"/>
        <cine:clasificacion rdf:resource="http://cinecolombia.com/clasificacion/Mayores12"/>
        <cine:director rdf:resource="http://cinecolombia.com/director/AaronHorvath"/>
        <cine:disponible3D rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</cine:disponible3D>
        <cine:distribuidora>Universal Pictures / Illumination</cine:distribuidora>
        <cine:enCartelera rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</cine:enCartelera>
        <rdfs:seeAlso rdf:resource="https://www.colombia.com/cine/super-mario-galaxy-la-pelicula-11013"/>
    </cine:Pelicula>

</rdf:RDF>
